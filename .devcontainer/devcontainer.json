{
  "name": "nikolaostolis.com",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "PROJECT_ID": "nikolaos-tolis-site",
    "SITE_ID": "nikolaos-tolis-site",
    "DOMAIN": "nikolaostolis.com",
    "WWW_DOMAIN": "www.nikolaostolis.com"
  },
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": {
      "label": "Astro dev server",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=nikolaostolis-firebase-config,target=/home/node/.config,type=volume"
  ],
  "postCreateCommand": "npm ci",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "github.vscode-pull-request-github",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
