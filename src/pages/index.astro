---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExpertiseCard from "../components/ExpertiseCard.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import PageShell from "../components/layout/PageShell.astro";
import Section from "../components/layout/Section.astro";
import { contactCta, expertise, focusAreas, hero } from "../content/profile";
---

<BaseLayout>
  <PageShell>
    <main>
      <Section class="hero" spacing="none">
        <div class="eyebrow">{hero.eyebrow}</div>

        <h1>{hero.title}</h1>

        <p class="lead">{hero.lead}</p>

        <div class="actions">
          {
            hero.links.map((link) => (
              <ButtonLink
                href={link.href}
                variant={link.variant ?? "secondary"}
                target={link.target}
              >
                {link.label}
              </ButtonLink>
            ))
          }
        </div>
      </Section>

      <Section id="experience" title="Selected focus areas">
        <div class="timeline">
          {
            focusAreas.map((item) => (
              <div class="item">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            ))
          }
        </div>
      </Section>

      <Section id="contact" title="Contact">
        <div class="card">
          <h3>{contactCta.title}</h3>
          <p>{contactCta.body}</p>
        </div>
      </Section>
    </main>
  </PageShell>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0 3rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    color: var(--color-accent);
    background: var(--color-accent-soft);
    font-size: var(--text-eyebrow);
    margin-bottom: 1.5rem;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
    margin: 0 0 1.5rem;
  }

  .lead {
    max-width: 760px;
    color: var(--color-text-muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    margin: 0 0 2rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .timeline {
    display: grid;
    gap: 1rem;
  }

  .item {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
  }

  .item h3 {
    margin: 0 0 0.25rem;
  }

  .item p {
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 800px) {
    .hero {
      padding-top: 2rem;
    }
  }
</style>
