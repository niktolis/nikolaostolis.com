---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExpertiseCard from "../components/ExpertiseCard.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import PageShell from "../components/layout/PageShell.astro";
import Section from "../components/layout/Section.astro";

const expertise = [
  {
    title: "Embedded & real-time software",
    body: "C/C++, RTOS concepts, MCU bring-up, diagnostics, boot/update flows, and production-grade embedded software design.",
  },
  {
    title: "Automotive platforms",
    body: "AUTOSAR Classic, UDS diagnostics, CAN/CAN FD, Ethernet-related integration, safety-oriented development, and platform software delivery.",
  },
  {
    title: "Architecture & technical leadership",
    body: "System decomposition, cross-team integration, technical decision-making, requirements clarification, and pragmatic delivery under constraints.",
  },
];
---

<BaseLayout>
  <PageShell>
    <main>
      <section class="hero">
        <div class="eyebrow">
          Software Architecture · Embedded Software · Automotive Systems
        </div>

        <h1>
          Engineering reliable software for complex automotive and embedded
          systems.
        </h1>

        <p class="lead">
          I am an embedded software engineer focused on AUTOSAR Classic,
          diagnostics, real-time systems, Linux, cloud-connected workflows, and
          software architecture for automotive platforms.
        </p>

        <ButtonLink href="/contact" variant="primary">Contact me</ButtonLink>
        <ButtonLink href="https://github.com/niktolis" target="_blank"
          >GitHub</ButtonLink
        >
        <ButtonLink href="https://www.linkedin.com/in/..." target="_blank"
          >LinkedIn</ButtonLink
        >
      </section>

      <Section id="expertise" title="Core expertise">
        <div class="grid">
          {
            expertise.map((item) => (
              <ExpertiseCard title={item.title} body={item.body} />
            ))
          }
        </div>
      </Section>

      <Section id="experience" title="Recent focus">
        <div class="timeline">
          <div class="item">
            <h3>Automotive ECU and platform software</h3>
            <p>
              Work across embedded platforms, diagnostics, communication stacks,
              and integration topics for modern vehicle systems.
            </p>
          </div>

          <div class="item">
            <h3>Software-defined vehicle and open-source technologies</h3>
            <p>
              Interest in Linux, Zephyr, cloud-connected tooling, reproducible
              development, and pragmatic use of open-source technologies in
              automotive contexts.
            </p>
          </div>

          <div class="item">
            <h3>Professional portfolio in progress</h3>
            <p>
              This website is being built as a central place for my engineering
              profile, projects, writing, and future consulting or one-person
              company activities.
            </p>
          </div>
        </div>
      </Section>

      <Section id="contact" title="Contact">
        <div class="card">
          <h3>Let’s connect</h3>
          <p>For now, reach me through GitHub, LinkedIn or Email.</p>
        </div>
      </Section>
    </main>
  </PageShell>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0 3rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    color: var(--color-accent);
    background: var(--color-accent-soft);
    font-size: var(--text-eyebrow);
    margin-bottom: 1.5rem;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
    margin: 0 0 1.5rem;
  }

  .lead {
    max-width: 760px;
    color: var(--color-text-muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    margin: 0 0 2rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .timeline {
    display: grid;
    gap: 1rem;
  }

  .item {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
  }

  .item h3 {
    margin: 0 0 0.25rem;
  }

  .item p {
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 800px) {
    .hero {
      padding-top: 2rem;
    }
  }
</style>
