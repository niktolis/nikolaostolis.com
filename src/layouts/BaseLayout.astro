---
import "../styles/global.css";
const {
  title = "Nikolaos Tolis | Embedded Software & Automotive Systems",
  description = "Personal website and professional portfolio of Nikolaos Tolis, embedded software engineer focused on automotive systems, AUTOSAR, Linux, cloud, and software architecture.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://nikolaostolis.com" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>

  <body>
    <slot />
  </body>
</html>
