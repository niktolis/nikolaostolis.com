---
import { site } from "../../config/site";

const year = new Date().getFullYear();
---

<footer>
  © {year}
  {site.name}. {site.footerText}
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
</style>
